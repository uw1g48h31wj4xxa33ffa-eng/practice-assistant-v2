{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://practice-assistant.local/schemas/ai-capability-profile.schema.json",
  "title": "AI Capability Profile",
  "type": "object",
  "allOf": [
    { "$ref": "base-profile.schema.json" }
  ],
  "properties": {
    "profileType": { "const": "ai-capability" },
    "provider": { "type": "string" },
    "model": { "type": "string" },
    "approvedTasks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "prohibitedTasks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "toolCapabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dataTransmissionPolicy": { "type": "string" },
    "retentionPolicy": { "type": "string" },
    "jurisdiction": { "type": "string" },
    "requiredGateStrength": { "type": "string" },
    "requiredHumanReview": { "type": "string" },
    "evaluationVersion": { "type": "string" },
    "fallbackPolicy": { "type": "string" }
  },
  "required": [
    "provider",
    "model"
  ]
}
